# ============================================
# DataFlow Finance — Environment template
# ============================================
# Copy this file to `.env` and adjust values for your deployment.
# Never commit the real `.env` — it is already in .gitignore.

# --- Application ---
DATAFLOW_APP_NAME="DataFlow Finance ETL"
DATAFLOW_API_VERSION=v1
DATAFLOW_DEBUG=false
DATAFLOW_LOG_LEVEL=INFO

# --- Business rules (decimal rates) ---
DATAFLOW_IFOOD_COMMISSION_RATE=0.23
DATAFLOW_CREDIT_CARD_FEE=0.0299
DATAFLOW_DEBIT_CARD_FEE=0.0149
DATAFLOW_PIX_FEE=0.0099
DATAFLOW_CASH_FEE=0.0

# --- Cash gap detection ---
DATAFLOW_GAP_TOLERANCE_BRL=0.05

# --- Output ---
DATAFLOW_OUTPUT_DIR=./output

# --- Security (production only) ---
# DATAFLOW_API_KEY=replace-with-long-random-string
# DATAFLOW_ALLOWED_ORIGINS=https://dataflowfinance.com.br

# --- Leads API (leave empty to disable auth in development) ---
# DATAFLOW_LEADS_API_KEY=replace-with-long-random-string
# Required in production to protect PII data at GET /api/v1/leads
